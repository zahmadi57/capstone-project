global
    log 127.0.0.1 local2
    chroot /var/lib/haproxy
    pidfile /var/run/haproxy.pid
    maxconn 4000
    daemon

defaults
    mode http
    log global
    option httplog
    option dontlognull
    option http-server-close
    option forwardfor except 127.0.0.0/8
    option redispatch
    retries 3
    timeout http-request 10s
    timeout queue 1m
    timeout connect 10s
    timeout client 1m
    timeout server 1m
    timeout http-keep-alive 10s
    timeout check 10s
    maxconn 3000

frontend main_http
    bind *:80
    default_backend web_nodes

backend web_nodes
    balance roundrobin
    # Dynamically loops through the 'webservers' group in the Ansible inventory to add backends
{% for host in groups['webservers'] %}
    server {{ host }} {{ host }}:80 check
{% endfor %}
